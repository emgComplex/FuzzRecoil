function m_log(msg)
	log("[FuzzRecoil]" .. msg)
end
function no_shot_effect(_)
	--m_log("Fired!!")
end
function on_game_start()
	if grok_bo_enhanced_recoil then
		grok_bo_enhanced_recoil.shoot_effect = no_shot_effect
		m_log("Recoil patched")
	else
		m_log("Can't find grok_bo_enhanced_recoil")
	end
end
